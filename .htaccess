# Disable directory listing
Options -Indexes

# Allow PHP execution
<FilesMatch "\.php$">
    Options +ExecCGI
</FilesMatch>

# Protect jobs and downloads directories
<FilesMatch "\.(spotdl|json|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow serving ZIP and MP3 directly via api.php
<FilesMatch "\.(zip|mp3|m4a|ogg)$">
    Header set Content-Disposition "attachment"
</FilesMatch>

# Increase PHP limits for large playlists
php_value max_execution_time 1800
php_value memory_limit 512M
php_value post_max_size 10M
php_value upload_max_filesize 10M

# Gzip compression for JSON
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/html text/css application/javascript
</IfModule>
